    "character_olya_title": "Olya, 14 years",
    "@character_olya_title": {
        "description": "Olya name + age"
    },
    "character_olya_quote": "\"I won't speak — I will show\"",
    "@character_olya_quote": {
        "description": "Olya short quote"
    },
    "character_olya_trait": "Autistic spectrum (ASD), hypersensitivity to loud sounds, bright light and chaos.",
    "@character_olya_trait": {
        "description": "Olya trait description"
    },
    "character_olya_superPower": "Remembers and structures space through visual patterns, drawings and geometry.",
    "@character_olya_superPower": {
        "description": "Olya super power"
    },
